# Supabase connection (optional).
# If these are left empty, the app automatically runs in LOCAL DEMO mode:
#   - content is read from src/lib/seedData.ts
#   - student progress is saved to the browser's localStorage
# Fill these in to connect to a real Supabase project (see supabase/schema.sql).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# PIN that unlocks the /admin Syllabus Manager. Defaults to "hsc2026admin"
# if unset. Set your own before release.
VITE_ADMIN_PIN=
